const totalCount = groups.reduce((sum, g) => sum + g.links.length, 0)
---

<SiteLayout
  seo_title="Sitemap — dummynotthink"
  meta_description="Full clickable list of every page on the dummynotthink staging site."
  canonical_url="https://dummynotthink.vercel.app/sitemap/"
  is_staging={false}
  silo="scavenger"
>
  <main>
    <section class="hero-simple">
      <p class="eyebrow">Staging Site</p>
      <h1>Sitemap</h1>
      <p class="lede">Every page currently live on dummynotthink.vercel.app — {totalCount} links, grouped by section.</p>
    </section>

    {groups.map(group => (
      <section class="section">
        <h2>{group.title}</h2>
        <ul class="link-list">
          {group.links.map(link => (
            <li><a href={link.href}>{link.label}</a><span class="path">{link.href}</span></li>
          ))}
        </ul>
      </section>
    ))}
  </main>
</SiteLayout>

<style>
  .hero-simple {
    padding: 44px 0 12px;
  }
  .lede {
    font-size: 1.1rem;
    max-width: 600px;
    margin-top: 12px;
  }
  .link-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    gap: 4px;
  }
  .link-list li {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 16px;
    padding: 11px 4px;
    border-bottom: 1px solid var(--border);
  }
  .link-list li:last-child {
    border-bottom: none;
  }
  .link-list a {
    font-weight: 750;
    text-decoration: none;
    color: var(--text-primary);
  }
  .link-list a:hover {
    color: #E8703A;
    text-decoration: underline;
  }
  .path {
    font-size: 0.8rem;
    color: var(--text-secondary);
    white-space: nowrap;
    font-family: monospace;
  }
  @media (max-width: 600px) {
    .link-list li {
      flex-direction: column;
      gap: 2px;
    }
  }
</style>
